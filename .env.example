# MB Hub — Variáveis de Ambiente

# API
REACT_APP_API_URL=https://api.mbhub.com
NODE_ENV=production

# WhatsApp
REACT_APP_WHATSAPP_NUMBER=5511999999999
REACT_APP_WHATSAPP_BUSINESS_API=https://api.whatsapp.com

# Google Drive
